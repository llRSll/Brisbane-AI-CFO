# --- Supabase ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server only, NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI (optional) ---
# If omitted, the app falls back to a built-in mock grouping/parsing engine
# so the demo still works offline.
OPENAI_API_KEY=sk-...

# --- Admin ---
# Password to access the /admin presenter dashboard.
ADMIN_PASSWORD=changeme

# --- App ---
# Public base URL (used to build the QR code link). On Vercel this is set
# automatically; for local dev leave as http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
